--loot table system using rng and tables
local lootTable = {
	{item = "Common Sword", chance = 60},
	{item = "Rare Sword", chance = 25},
	{item = "Epic Sword", chance = 10},
	{item = "Legendary Sword", chance = 5}
}

local roll = math.random(1,100)
local currentChance = 0

for i = 1,#lootTable do
	currentChance += lootTable[i].chance
	
	if roll <= currentChance then
		print("You got:",lootTable[i].item)
		break
	end
end
